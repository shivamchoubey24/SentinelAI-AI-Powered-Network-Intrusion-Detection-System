# Environment Configuration
# Copy this file to .env and fill in your actual values

# Google Gemini API
GEMINI_API_KEY=""

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=network_security
POSTGRES_URI=postgresql://user:password@localhost:5432/security_db

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=network-security-data

# Blockchain Configuration
BLOCKCHAIN_NETWORK=development
ETHEREUM_NODE_URL=http://localhost:8545
CONTRACT_ADDRESS=
IPFS_HOST=localhost
IPFS_PORT=5001

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
DAGSHUB_TOKEN=your_dagshub_token

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_LOGS=security-logs
KAFKA_TOPIC_ALERTS=security-alerts

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your_secret_key_for_jwt

# Alert Configuration
ALERT_EMAIL=security-alerts@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Model Configuration
MODEL_RETRAIN_INTERVAL=7  # days
MODEL_PERFORMANCE_THRESHOLD=0.85

# Dashboard Configuration
DASHBOARD_PORT=8501
DASHBOARD_TITLE=AI Network Security System

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/application.log

# Feature Flags
ENABLE_BLOCKCHAIN=true
ENABLE_MLOPS=true
ENABLE_REAL_TIME_ALERTS=true
ENABLE_AUTO_RETRAIN=true
